# ============================================================================
# Contoso Customer Support Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values before deployment

# ============================================================================
# AZURE SUBSCRIPTION AND RESOURCE CONFIGURATION
# ============================================================================

# Your Azure Subscription ID (find in Azure Portal or run: az account show)
# Required
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Resource group name for all Azure resources
# Recommended format: rg-<project>-<environment>-<number>
# Example: rg-contoso-dev-001
# Required
AZURE_RESOURCE_GROUP=rg-contoso-dev-001

# Azure region where resources will be deployed
# Options: eastus, northcentralus, westus2, uksouth, etc.
# Note: Some regions may have limited Foundry availability
# Recommended: northcentralus (best support for preview features)
# Required
AZURE_LOCATION=northcentralus

# ============================================================================
# AZURE FOUNDRY CONFIGURATION
# ============================================================================

# Foundry project name (alphanumeric, hyphens allowed)
# This is set during deployment
# Example: contoso-support-agent-dev
FOUNDRY_PROJECT_NAME=contoso-support-agent-dev

# Foundry hub name (typically same as project or your organization)
FOUNDRY_HUB_NAME=contoso

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Azure OpenAI deployment name (the model you want to use)
# Common options: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Default: gpt-4o-mini (cost-effective for demo)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ============================================================================
# MCP SERVICE CONFIGURATION
# ============================================================================

# Note: The following are set automatically during deployment
# You may need to update them if you change the deployment

# MCP Service URL - the endpoint where the MCP service is deployed
# Format: https://<service-name>.azurecontainerapps.io/mcp
# THIS MUST BE UPDATED during/after deployment
# Get this from: Azure Portal > Container Apps > Your MCP Service > Ingress > Application URL
# Example: https://my-contoso-mcp-12345.northcentralus.azurecontainerapps.io/mcp
MCP_SERVICE_URL=<your-mcp-service-url>/mcp

# Disable MCP authentication for local testing
# Set to 'false' for production
# Options: true | false
DISABLE_AUTH=true

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================================

# Environment name (for organizing multiple deployments)
# Example: dev, staging, prod
ENVIRONMENT_NAME=dev

# Cost management - enable monitoring
# Set to 'true' to create Application Insights and Log Analytics
ENABLE_MONITORING=true

# Container image settings
# Usually you don't need to change these
AZURE_CONTAINER_REGISTRY_NAME=contosocr
AZURE_CONTAINER_REGISTRY_SKU=Standard

# ============================================================================
# OPTIONAL: AUTHENTICATION (for production use)
# ============================================================================

# Azure Entra ID tenant ID (for securing the MCP service)
# Get this from: Azure Portal > Azure Entra ID > Overview
# Leave blank for public/dev environments
AAD_TENANT_ID=

# MCP API audience (for token validation)
# Example: api://contoso-mcp
MCP_API_AUDIENCE=

# Public base URL for MCP service
# Used for authentication callbacks
# THIS MUST BE UPDATED during/after deployment (same as MCP service URL without /mcp)
# Example: https://my-contoso-mcp-12345.northcentralus.azurecontainerapps.io
PUBLIC_BASE_URL=<your-mcp-service-base-url>

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. REQUIRED FIELDS (must fill in):
#    - AZURE_SUBSCRIPTION_ID
#    - AZURE_RESOURCE_GROUP
#    - AZURE_LOCATION
#
# 2. RECOMMENDED FOR TESTING:
#    - Use DISABLE_AUTH=true for initial setup
#    - Enable ENABLE_MONITORING=true to debug issues
#
# 3. FOR PRODUCTION:
#    - Enable authentication (AAD_TENANT_ID, MCP_API_AUDIENCE)
#    - Set ENABLE_MONITORING=true for production logging
#    - Use managed identity instead of keys
#    - Store sensitive values in Azure Key Vault
#
# 4. DEPLOYMENT:
#    - Run: azd up
#    - This reads your .env file and deploys resources
#    - Check .azure/<env-name>/.env for deployment-specific values
#
